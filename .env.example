APP_EMAIL_FROM_NAME=TravelBox Peru
APP_EMAIL_BRAND_NAME=TravelBox Peru
APP_EMAIL_QUEUE_ENABLED=true
APP_EMAIL_QUEUE_POLL_MS=3000
APP_EMAIL_QUEUE_BATCH_SIZE=20
APP_EMAIL_QUEUE_WORKER_THREADS=4
APP_EMAIL_QUEUE_MAX_ATTEMPTS=5
APP_EMAIL_QUEUE_RETRY_BACKOFF_SECONDS=30

# Graph API (Azure Communication Services) - Usa AZURE_CLIENT_ID y AZURE_CLIENT_SECRET deltenant
APP_EMAIL_GRAPH_TENANT_ID=
APP_EMAIL_GRAPH_CLIENT_ID=
APP_EMAIL_GRAPH_CLIENT_SECRET=

# SMTP (Legacy - solo si APP_EMAIL_PROVIDER=smtp)
