AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_KEYVAULT_ENDPOINT=https://kvtravelboxpe.vault.azure.net/
AZURE_KEYVAULT_ENABLED=true

# ===== TRANSLATION (Azure Translator) =====
# Providers: local, google, azure
APP_TRANSLATION_PROVIDER=azure
APP_TRANSLATION_ALLOW_FALLBACK=true
APP_TRANSLATION_CACHE_SECONDS=43200
APP_TRANSLATION_AZURE_API_KEY=
APP_TRANSLATION_AZURE_REGION=eastus

# ===== ROUTING (Azure Maps) =====
# Providers: osrm (free, default), google, azure
APP_ROUTING_PROVIDER=osrm
APP_ROUTING_ALLOW_MOCK_FALLBACK=true
APP_ROUTING_OSRM_BASE_URL=https://router.project-osrm.org
APP_ROUTING_OSRM_PROFILE=driving
APP_ROUTING_GOOGLE_BASE_URL=https://routes.googleapis.com
APP_ROUTING_GOOGLE_API_KEY=
APP_ROUTING_GOOGLE_FIELD_MASK=routes.duration,routes.distanceMeters,routes.polyline.encodedPolyline
APP_ROUTING_AZURE_BASE_URL=https://atlas.microsoft.com
APP_ROUTING_AZURE_MAPS_KEY=

