APP_SMTP_PORT=587
APP_SMTP_USERNAME=
APP_SMTP_PASSWORD=
APP_SMTP_AUTH=true
APP_SMTP_STARTTLS=true

# ===== AZURE CONFIGURATION =====
# Azure credentials para Key Vault, Graph API, etc.
