SERVER_TOMCAT_CONNECTION_TIMEOUT=10s
SERVER_TOMCAT_KEEP_ALIVE_TIMEOUT=20s
SERVER_TOMCAT_MAX_KEEP_ALIVE_REQUESTS=1000
APP_GRACEFUL_SHUTDOWN_TIMEOUT=30s

